<section class="min-h-screen bg-base-200 px-4 py-12">
    <div class="mx-auto flex max-w-md items-center justify-center">
        <div class="card w-full border border-base-300 bg-base-100 shadow-lg">
            <div class="card-body">
                <h1 class="text-center text-3xl font-bold">Login</h1>
                <p class="text-center text-base-content/70">Sign in to your account.</p>

                <% if (error) { %>
                    <div class="alert alert-error mb-4">
                        <span><%= error %></span>
                    </div>
                <% } %>

                <form action="/login" method="POST">
                    <div class="form-control">
                        <label class="label" for="email"><span class="label-text">Email</span></label>
                        <input id="email" type="email" name="email" class="input input-bordered" value="<%= formData.email %>" autocomplete="username" autocapitalize="off" spellcheck="false" required />
                    </div>
                    <div class="form-control">
                        <label class="label" for="password"><span class="label-text">Password</span></label>
                        <input id="password" type="password" name="password" class="input input-bordered" autocomplete="current-password" required />
                    </div>
                    <div class="form-control mt-6">
                        <button class="btn btn-primary">Login</button>
                    </div>
                </form>

                <div class="mt-4 text-center text-sm text-base-content/70">
                    <p><a class="link link-primary" href="/signup">Create account</a></p>
                    <p class="mt-1"><a class="link" href="/">Back home</a></p>
                </div>
            </div>
        </div>
    </div>
</section>
