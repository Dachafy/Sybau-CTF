<section class="min-h-screen bg-base-200 px-4 py-12">
    <div class="mx-auto flex max-w-md items-center justify-center">
        <div class="card w-full border border-base-300 bg-base-100 shadow-lg">
            <div class="card-body items-center text-center">
                <h1 class="text-3xl font-bold">User Portal</h1>
                <p class="text-base-content/70">Simple login and register system with MySQL.</p>

                <div class="mt-4 flex w-full flex-col gap-3">
                    <% if (currentUser) { %>
                        <a class="btn btn-primary w-full" href="/dashboard">Open Dashboard</a>
                        <form action="/logout" method="POST">
                            <button class="btn btn-outline w-full" type="submit">Logout</button>
                        </form>
                    <% } else { %>
                        <a class="btn btn-primary w-full" href="/login">Login</a>
                        <a class="btn btn-outline w-full" href="/signup">Register</a>
                    <% } %>
                </div>
            </div>
        </div>
    </div>
</section>
