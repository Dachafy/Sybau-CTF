<section class="min-h-screen bg-base-200 px-4 py-12">
  <div class="mx-auto flex max-w-6xl items-center gap-8">
    <div class="hidden flex-1 rounded-box border border-primary/20 bg-base-300 p-10 lg:block">
      <p class="mb-3 text-sm font-mono uppercase tracking-[0.3em] text-primary">Account Access</p>
      <h1 class="mb-4 text-5xl font-black uppercase leading-none">Create your secure user profile.</h1>
      <p class="max-w-md text-base-content/70">
        Registration stores the user in MySQL, hashes the password with bcrypt, and starts a protected session cookie after signup.
      </p>
      <div class="mt-8 space-y-3 text-sm text-base-content/70">
        <p>Stored fields: first name, last name, email, gender, province.</p>
        <p>Session protection: httpOnly, sameSite=lax, secure in production HTTPS.</p>
      </div>
    </div>

    <div class="w-full flex-1">
      <div class="card border border-base-300 bg-base-100 shadow-xl">
        <div class="card-body">
          <div class="mb-4">
            <p class="text-sm font-mono uppercase tracking-[0.25em] text-primary">Sign Up</p>
            <h2 class="card-title text-3xl font-black">Create an account</h2>
            <p class="text-sm text-base-content/70">Already registered? <a class="link link-primary" href="/login">Log in</a>.</p>
          </div>

          <% if (error) { %>
            <div class="alert alert-error mb-4">
              <span><%= error %></span>
            </div>
          <% } %>

          <form class="grid grid-cols-1 gap-4 md:grid-cols-2" method="POST" action="/signup">
            <div class="form-control">
              <label class="label" for="firstName"><span class="label-text">First Name</span></label>
              <input id="firstName" type="text" name="firstName" placeholder="First Name" class="input input-bordered w-full" value="<%= formData.firstName %>" required />
            </div>

            <div class="form-control">
              <label class="label" for="lastName"><span class="label-text">Last Name</span></label>
              <input id="lastName" type="text" name="lastName" placeholder="Last Name" class="input input-bordered w-full" value="<%= formData.lastName %>" required />
            </div>

            <div class="form-control md:col-span-2">
              <label class="label" for="email"><span class="label-text">Email</span></label>
              <input id="email" type="email" name="email" placeholder="email@example.com" class="input input-bordered w-full" value="<%= formData.email %>" required />
            </div>

            <div class="form-control">
              <label class="label" for="password"><span class="label-text">Password</span></label>
              <input id="password" type="password" name="password" placeholder="At least 8 characters" class="input input-bordered w-full" minlength="8" required />
            </div>

            <div class="form-control">
              <label class="label" for="confirmPassword"><span class="label-text">Confirm Password</span></label>
              <input id="confirmPassword" type="password" name="confirmPassword" placeholder="Re-enter password" class="input input-bordered w-full" minlength="8" required />
            </div>

            <div class="form-control">
              <label class="label"><span class="label-text">Gender</span></label>
              <div class="mt-2 flex gap-4">
                <label class="label cursor-pointer gap-2">
                  <input type="radio" name="gender" class="radio radio-primary" value="male" <%= formData.gender === 'male' ? 'checked' : '' %> required />
                  <span class="label-text">Male</span>
                </label>
                <label class="label cursor-pointer gap-2">
                  <input type="radio" name="gender" class="radio radio-primary" value="female" <%= formData.gender === 'female' ? 'checked' : '' %> required />
                  <span class="label-text">Female</span>
                </label>
              </div>
            </div>

            <div class="form-control">
              <label class="label" for="province"><span class="label-text">Province</span></label>
              <select id="province" class="select select-bordered w-full" name="province" required>
                <option value="" <%= !formData.province ? 'selected' : '' %> disabled>Pick your province</option>
                <option value="Kompong Cham" <%= formData.province === 'Kompong Cham' ? 'selected' : '' %>>Kompong Cham</option>
                <option value="Kompong Thom" <%= formData.province === 'Kompong Thom' ? 'selected' : '' %>>Kompong Thom</option>
                <option value="Phnom Penh" <%= formData.province === 'Phnom Penh' ? 'selected' : '' %>>Phnom Penh</option>
                <option value="Siem Reap" <%= formData.province === 'Siem Reap' ? 'selected' : '' %>>Siem Reap</option>
              </select>
            </div>

            <div class="form-control mt-4 md:col-span-2">
              <button class="btn btn-primary">Create Account</button>
            </div>
          </form>
        </div>
      </div>
    </div>
  </div>
</section>
