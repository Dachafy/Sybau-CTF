<section class="min-h-screen bg-base-200 px-4 py-10">
    <div class="mx-auto flex max-w-lg items-center justify-center">
        <div class="card w-full border border-base-300 bg-base-100 shadow-lg">
            <div class="card-body">
                <div class="flex items-start justify-between gap-4">
                    <div>
                        <h1 class="text-3xl font-bold">Dashboard</h1>
                        <p class="text-base-content/70">Your profile information.</p>
                    </div>
                    <form action="/logout" method="POST">
                        <button type="submit" class="btn btn-outline btn-sm">Logout</button>
                    </form>
                </div>

                <div class="mt-4 space-y-3">
                    <div>
                        <p class="text-sm text-base-content/60">Name</p>
                        <p class="font-medium"><%= profile.first_name %> <%= profile.last_name %></p>
                    </div>
                    <div>
                        <p class="text-sm text-base-content/60">Email</p>
                        <p class="font-medium"><%= profile.email %></p>
                    </div>
                    <div>
                        <p class="text-sm text-base-content/60">Gender</p>
                        <p class="font-medium capitalize"><%= profile.gender %></p>
                    </div>
                    <div>
                        <p class="text-sm text-base-content/60">Province</p>
                        <p class="font-medium"><%= profile.province %></p>
                    </div>
                    <div>
                        <p class="text-sm text-base-content/60">Joined</p>
                        <p class="font-medium"><%= new Date(profile.created_at).toLocaleDateString() %></p>
                    </div>
                </div>

                <a href="/" class="btn btn-primary mt-6">Back Home</a>
            </div>
        </div>
    </div>
</section>
